---
import Layout from './Layout.astro';

interface Props {
  title?: string;
}

const { title = '文章' } = Astro.props;
---

<Layout title={title}>
  <section class="article-layout mx-auto flex w-full max-w-360 items-start justify-center gap-8">
    <article class="article-content min-w-0 w-full max-w-4xl">
      <div data-article-content class="prose prose-gray max-w-none prose-headings:font-extrabold prose-headings:scroll-mt-22 prose-a:text-teal-700 hover:prose-a:text-teal-600 prose-code:before:content-none prose-code:after:content-none dark:prose-invert dark:prose-a:text-teal-300">
        <slot />
      </div>
    </article>

    <button class="toc-fab fixed right-4 bottom-4 z-52 hidden h-[2.85rem] min-w-[2.85rem] items-center justify-center rounded-full bg-teal-700 px-4 text-[0.9rem] font-bold tracking-[0.03em] text-teal-50 shadow-[0_16px_28px_rgb(15_118_110/0.32)] transition-[transform,opacity] duration-200 motion-reduce:transition-none dark:bg-teal-600 dark:text-cyan-50 max-lg:inline-flex aria-expanded:pointer-events-none aria-expanded:translate-y-2.5 aria-expanded:scale-95 aria-expanded:opacity-0" type="button" aria-controls="article-toc" aria-expanded="false">
      目录
    </button>

    <div class="toc-mobile-backdrop fixed inset-0 z-50 hidden bg-slate-900/42 opacity-0 pointer-events-none transition-opacity duration-200 motion-reduce:transition-none max-lg:block data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto" data-open="false" hidden aria-hidden="true"></div>

    <aside class="toc-shell group/toc sticky top-20 z-20 flex max-h-[calc(100vh-6rem)] w-75 self-start flex-col overflow-hidden rounded-2xl border border-gray-300/85 bg-linear-to-br from-white/95 to-gray-50/88 shadow-[0_16px_36px_rgb(15_23_42/0.10)] backdrop-blur-xl transition-[width,box-shadow,border-color,background-color,transform,opacity] duration-300 motion-reduce:transition-none dark:border-gray-600/75 dark:from-gray-900/93 dark:to-slate-900/86 dark:shadow-[0_18px_36px_rgb(0_0_0/0.36)] lg:data-[open=false]:w-[3.4rem] lg:data-[open=false]:rounded-2xl lg:data-[open=false]:border-slate-400/60 lg:data-[open=false]:bg-white/95 lg:data-[open=false]:shadow-[0_12px_26px_rgb(15_23_42/0.16)] dark:lg:data-[open=false]:border-slate-500/70 dark:lg:data-[open=false]:bg-slate-900/93 dark:lg:data-[open=false]:shadow-[0_16px_26px_rgb(0_0_0/0.40)] max-lg:fixed max-lg:inset-x-3 max-lg:bottom-3 max-lg:top-auto max-lg:w-auto max-lg:max-h-[min(75vh,34rem)] max-lg:z-55 max-lg:translate-y-[calc(100%+1rem)] max-lg:opacity-0 max-lg:pointer-events-none max-lg:data-[open=true]:translate-y-0 max-lg:data-[open=true]:opacity-100 max-lg:data-[open=true]:pointer-events-auto" data-open="true" aria-label="文章目录">
      <button class="toc-toggle flex w-full items-center justify-start gap-2 border-b border-gray-300/90 bg-transparent px-3 py-[0.78rem] text-[0.86rem] font-bold tracking-[0.02em] transition-colors duration-200 hover:bg-teal-500/10 disabled:cursor-not-allowed disabled:opacity-60 motion-reduce:transition-none dark:border-gray-600/80 dark:hover:bg-teal-500/15 lg:group-data-[open=false]/toc:min-h-[3.4rem] lg:group-data-[open=false]/toc:justify-center lg:group-data-[open=false]/toc:border-b-0 lg:group-data-[open=false]/toc:px-[0.55rem]" type="button" aria-expanded="true" aria-controls="article-toc">
        <span class="toc-toggle-icon inline-flex h-[1.72rem] w-[1.72rem] shrink-0 items-center justify-center rounded-full bg-teal-700/12 text-[1.02rem] leading-none text-teal-700 transition-[transform,background-color,color] duration-200 motion-reduce:transition-none dark:bg-teal-300/20 dark:text-teal-200 rotate-180 group-data-[open=false]/toc:rotate-0" aria-hidden="true">›</span>
        <span class="toc-toggle-label max-w-36 overflow-hidden whitespace-nowrap opacity-100 transition-[max-width,opacity] duration-200 motion-reduce:transition-none lg:group-data-[open=false]/toc:max-w-0 lg:group-data-[open=false]/toc:opacity-0">收起目录</span>
      </button>
      <nav id="article-toc" class="toc-nav max-h-[calc(100vh-10rem)] overflow-auto px-2.5 pt-2 pb-3.5 lg:group-data-[open=false]/toc:hidden max-lg:max-h-[min(calc(75vh-3.35rem),28rem)]" aria-label="文章目录导航">
        <p class="toc-empty mx-2 my-1.5 text-sm text-gray-500 dark:text-gray-400">正在生成目录...</p>
      </nav>
    </aside>
  </section>

  <script is:inline>
    (() => {
      const articleRoot = document.querySelector('[data-article-content]');
      const tocShell = document.querySelector('.toc-shell');
      const tocNav = document.getElementById('article-toc');
      const toggleButton = tocShell?.querySelector('.toc-toggle');
      const toggleLabel = tocShell?.querySelector('.toc-toggle-label');
      const tocFab = document.querySelector('.toc-fab');
      const mobileBackdrop = document.querySelector('.toc-mobile-backdrop');
      const mobileQuery = window.matchMedia('(max-width: 1023px)');

      if (!articleRoot || !tocShell || !tocNav || !toggleButton || !toggleLabel) {
        return;
      }

      const getDesktopPreference = () => {
        const saved = window.localStorage.getItem('article-toc-open');
        return saved == null ? true : saved === '1';
      };

      const slugify = (value) => {
        const normalized = value
          .trim()
          .toLowerCase()
          .replace(/[\s]+/g, '-')
          .replace(/[^\p{Letter}\p{Number}-]/gu, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '');
        return normalized;
      };

      const getHashId = (value) => {
        const raw = (value || '').replace(/^#/, '');
        if (!raw) {
          return '';
        }

        try {
          return decodeURIComponent(raw);
        } catch {
          return raw;
        }
      };

      let headings = Array.from(articleRoot.querySelectorAll('h2, h3, h4'));
      if (headings.length === 0) {
        headings = Array.from(articleRoot.querySelectorAll('h1'));
      }

      if (headings.length === 0) {
        const emptyMessage = document.createElement('p');
        emptyMessage.className = 'mx-2 my-1.5 text-sm text-gray-500 dark:text-gray-400';
        emptyMessage.textContent = '本文没有可索引的小节。';
        tocNav.replaceChildren(emptyMessage);
        toggleButton.disabled = true;
        toggleButton.setAttribute('aria-disabled', 'true');
        if (tocFab instanceof HTMLButtonElement) {
          tocFab.hidden = true;
        }
        if (mobileBackdrop instanceof HTMLDivElement) {
          mobileBackdrop.hidden = true;
          mobileBackdrop.dataset.open = 'false';
        }
        return;
      }

      const tocListClassName = 'm-0 flex list-none flex-col gap-1 p-0';
      const tocItemClassName = 'm-0 min-w-0';
      const tocLinkClassName =
        'block truncate rounded-md border-l-[3px] border-l-transparent px-2.5 py-1.5 text-[0.88rem] font-medium leading-[1.38] text-gray-600 no-underline transition-[background-color,color,transform,border-color] duration-200 hover:translate-x-px hover:border-l-teal-700 hover:bg-teal-400/25 hover:text-teal-700 focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-teal-500 motion-reduce:transition-none dark:text-slate-300 dark:hover:border-l-teal-300 dark:hover:bg-teal-400/30 dark:hover:text-teal-100 [&.is-active]:border-l-teal-600 [&.is-active]:bg-teal-400/30 [&.is-active]:font-bold [&.is-active]:text-teal-900 dark:[&.is-active]:border-l-teal-300 dark:[&.is-active]:bg-teal-400/25 dark:[&.is-active]:text-teal-100';

      const allIds = new Set(
        Array.from(document.querySelectorAll('[id]'))
          .map((element) => element.id)
          .filter(Boolean)
      );

      const minLevel = headings.reduce((smallest, heading) => {
        const current = Number(heading.tagName.slice(1));
        return current < smallest ? current : smallest;
      }, 6);

      const tocList = document.createElement('ul');
      tocList.className = tocListClassName;

      const entries = headings.map((heading, index) => {
        const fallbackId = `section-${index + 1}`;
        const baseId = heading.id || slugify(heading.textContent || '') || fallbackId;
        let nextId = baseId;
        let duplicateCounter = 2;

        while (allIds.has(nextId)) {
          if (nextId === heading.id) {
            break;
          }
          nextId = `${baseId}-${duplicateCounter}`;
          duplicateCounter += 1;
        }

        if (!heading.id) {
          heading.id = nextId;
        }
        allIds.add(heading.id);

        const level = Number(heading.tagName.slice(1));
        const indentLevel = Math.max(level - minLevel, 0);

        const listItem = document.createElement('li');
        listItem.className = tocItemClassName;
        listItem.style.marginLeft = `${indentLevel * 0.85}rem`;

        const link = document.createElement('a');
        link.className = tocLinkClassName;
        link.href = `#${heading.id}`;
        link.textContent = heading.textContent?.trim() || `小节 ${index + 1}`;
        link.title = link.textContent;

        listItem.append(link);
        tocList.append(listItem);

        return { heading, link };
      });

      tocNav.replaceChildren(tocList);

      const setOpenState = (isOpen, options = {}) => {
        const { persistDesktop = true } = options;
        const isMobile = mobileQuery.matches;

        tocShell.dataset.open = isOpen ? 'true' : 'false';
        toggleButton.setAttribute('aria-expanded', String(isOpen));

        if (tocFab instanceof HTMLButtonElement) {
          tocFab.setAttribute('aria-expanded', String(isOpen));
        }

        if (isMobile) {
          toggleLabel.textContent = isOpen ? '关闭目录' : '目录';
          if (mobileBackdrop instanceof HTMLDivElement) {
            mobileBackdrop.dataset.open = isOpen ? 'true' : 'false';
            mobileBackdrop.hidden = !isOpen;
          }
          document.body.classList.toggle('overflow-hidden', isOpen);
          return;
        }

        toggleLabel.textContent = isOpen ? '收起目录' : '展开目录';

        if (mobileBackdrop instanceof HTMLDivElement) {
          mobileBackdrop.dataset.open = 'false';
          mobileBackdrop.hidden = true;
        }

        document.body.classList.remove('overflow-hidden');

        if (persistDesktop) {
          window.localStorage.setItem('article-toc-open', isOpen ? '1' : '0');
        }
      };

      if (mobileQuery.matches) {
        setOpenState(false, { persistDesktop: false });
      } else {
        setOpenState(getDesktopPreference(), { persistDesktop: false });
      }

      toggleButton.addEventListener('click', () => {
        setOpenState(tocShell.dataset.open !== 'true');
      });

      if (tocFab instanceof HTMLButtonElement) {
        tocFab.addEventListener('click', () => {
          setOpenState(true, { persistDesktop: false });
        });
      }

      if (mobileBackdrop instanceof HTMLDivElement) {
        mobileBackdrop.addEventListener('click', () => {
          setOpenState(false, { persistDesktop: false });
        });
      }

      const setActiveLink = (activeId) => {
        entries.forEach(({ link }) => {
          const isActive = link.getAttribute('href') === `#${activeId}`;
          link.classList.toggle('is-active', isActive);
        });
      };

      const initialHash = getHashId(window.location.hash);
      setActiveLink(initialHash || entries[0].heading.id);

      const observer = new IntersectionObserver(
        (intersections) => {
          const visible = intersections
            .filter((item) => item.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible[0]) {
            setActiveLink(visible[0].target.id);
          }
        },
        {
          rootMargin: '-20% 0px -65% 0px',
          threshold: [0, 1],
        }
      );

      entries.forEach(({ heading }) => observer.observe(heading));

      tocNav.addEventListener('click', (event) => {
        if (!(event.target instanceof Element)) {
          return;
        }

        const anchor = event.target.closest('a');
        if (!anchor) {
          return;
        }

        const hashId = getHashId(anchor.hash);
        if (hashId) {
          setActiveLink(hashId);
        }

        if (mobileQuery.matches) {
          setOpenState(false, { persistDesktop: false });
        }
      });

      window.addEventListener('hashchange', () => {
        const hashId = getHashId(window.location.hash);
        if (hashId) {
          setActiveLink(hashId);
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && mobileQuery.matches && tocShell.dataset.open === 'true') {
          setOpenState(false, { persistDesktop: false });
        }
      });

      const handleViewportChange = () => {
        if (mobileQuery.matches) {
          setOpenState(false, { persistDesktop: false });
          return;
        }

        setOpenState(getDesktopPreference(), { persistDesktop: false });
      };

      if (typeof mobileQuery.addEventListener === 'function') {
        mobileQuery.addEventListener('change', handleViewportChange);
      } else if (typeof mobileQuery.addListener === 'function') {
        mobileQuery.addListener(handleViewportChange);
      }
    })();
  </script>

</Layout>
