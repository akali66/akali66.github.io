---
import Layout from './Layout.astro';

interface Props {
  title?: string;
}

const { title = '文章' } = Astro.props;
---

<Layout title={title}>
  <article class="mx-auto w-full max-w-4xl">
    <div class="prose prose-gray max-w-none prose-headings:font-extrabold prose-a:text-teal-700 hover:prose-a:text-teal-600 prose-code:before:content-none prose-code:after:content-none dark:prose-invert dark:prose-a:text-teal-300">
      <slot />
    </div>
  </article>
</Layout>
