---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="个人小站" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				const storedTheme = window.localStorage.getItem('theme');
				const theme =
					storedTheme === 'light' || storedTheme === 'dark'
						? storedTheme
						: window.matchMedia('(prefers-color-scheme: dark)').matches
							? 'dark'
							: 'light';

				document.documentElement.classList.toggle('dark', theme === 'dark');
				document.documentElement.style.colorScheme = theme;
				window.localStorage.setItem('theme', theme);
			})();
		</script>
		<title>{title}</title>
	</head>
	<body class="min-h-screen md:flex md:flex-row">
		<Sidebar />
		<main class="bg-gray-50 p-6 transition-colors duration-300 dark:bg-gray-800 md:flex-1 md:border-l md:p-12 border-gray-200 dark:border-gray-700">
			<slot />
		</main>
	</body>
</html>
