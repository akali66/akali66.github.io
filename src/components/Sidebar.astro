---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/articles', label: '文章' },
  { href: '/projects', label: '项目' },
];

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(`${href}/`));
---
<div class="sticky top-0 z-40 border-b border-gray-200 bg-white/95 px-4 py-3 backdrop-blur-sm transition-colors duration-300 dark:border-gray-700 dark:bg-gray-900/95 md:hidden">
  <div class="flex items-center justify-between gap-3">
    <a href="/" class="text-lg font-bold tracking-tight text-gray-900 dark:text-white sillycat-trigger">SillyCat</a>

    <div class="flex items-center gap-2">
      <button
        type="button"
        data-theme-toggle
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-gray-600 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white"
        aria-label="切换深浅主题"
      >
        <svg data-theme-icon="light" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg data-theme-icon="dark" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button
        type="button"
        id="mobile-menu-open"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-gray-700 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white"
        aria-controls="mobile-drawer-root"
        aria-expanded="false"
        aria-label="打开导航菜单"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</div>

<div
  id="mobile-drawer-root"
  class="fixed inset-0 z-50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  aria-hidden="true"
>
  <button
    type="button"
    id="mobile-drawer-overlay"
    class="absolute inset-0 bg-black/45"
    aria-label="关闭导航菜单"
  ></button>

  <aside
    id="mobile-drawer"
    class="absolute right-0 top-0 flex h-full w-72 max-w-[85vw] translate-x-full flex-col border-l border-gray-200 bg-white p-6 shadow-xl transition-transform duration-300 dark:border-gray-700 dark:bg-gray-900"
  >
    <div class="mb-8 flex items-start justify-between gap-3">
      <div>
        <h2 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white sillycat-trigger">SillyCat</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">个人小站</p>
      </div>
      <button
        type="button"
        id="mobile-menu-close"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-gray-600 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white"
        aria-label="关闭导航菜单"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="grow space-y-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-mobile-nav-link
          class:list={[
            'block rounded-lg px-4 py-2 font-medium transition-colors duration-200',
            isActive(item.href)
              ? 'bg-gray-900 text-white dark:bg-white dark:text-gray-900'
              : 'text-gray-700 hover:bg-gray-100 hover:text-black dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      type="button"
      data-theme-toggle
      class="mt-6 flex w-full items-center gap-2 rounded-lg p-2 text-sm text-gray-600 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
      aria-label="切换深浅主题"
    >
      <svg data-theme-icon="light" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg data-theme-icon="dark" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      <span data-theme-label>深色模式</span>
    </button>
  </aside>
</div>

<aside class="hidden w-full min-h-screen flex-col border-r border-gray-200 bg-white p-6 transition-colors duration-300 dark:border-gray-800 dark:bg-gray-900 md:sticky md:top-0 md:flex md:h-screen md:w-64 md:flex-none">
  <div class="mb-10">
    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white sillycat-trigger">SillyCat</h1>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">个人小站</p>
  </div>

  <nav class="grow space-y-2">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'block rounded-lg px-4 py-2 font-medium transition-colors duration-200',
          isActive(item.href)
            ? 'bg-gray-900 text-white dark:bg-white dark:text-gray-900'
            : 'text-gray-700 hover:bg-gray-100 hover:text-black dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>

  <div class="mt-auto">
    <button
      type="button"
      data-theme-toggle
      class="flex w-full items-center gap-2 rounded-lg p-2 text-sm text-gray-600 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
      aria-label="切换深浅主题"
    >
      <svg data-theme-icon="light" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg data-theme-icon="dark" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      <span data-theme-label>深色模式</span>
    </button>
  </div>
</aside>

<script>
  const getThemeButtons = () => document.querySelectorAll<HTMLElement>('[data-theme-toggle]');

  const getDrawerElements = () => ({
    drawerRoot: document.getElementById('mobile-drawer-root'),
    drawerPanel: document.getElementById('mobile-drawer'),
    openButton: document.getElementById('mobile-menu-open'),
    closeButton: document.getElementById('mobile-menu-close'),
    overlayButton: document.getElementById('mobile-drawer-overlay'),
  });

  const isDarkMode = () => document.documentElement.classList.contains('dark');

  const updateThemeUI = () => {
    const dark = isDarkMode();

    getThemeButtons().forEach((button) => {
      const lightIcon = button.querySelector('[data-theme-icon="light"]');
      const darkIcon = button.querySelector('[data-theme-icon="dark"]');
      const themeLabel = button.querySelector('[data-theme-label]');

      lightIcon?.classList.toggle('hidden', !dark);
      darkIcon?.classList.toggle('hidden', dark);

      if (themeLabel) {
        themeLabel.textContent = dark ? '浅色模式' : '深色模式';
      }
    });
  };

  const toggleTheme = () => {
    const nextTheme = isDarkMode() ? 'light' : 'dark';

    document.documentElement.classList.toggle('dark', nextTheme === 'dark');
    document.documentElement.style.colorScheme = nextTheme;
    localStorage.setItem('theme', nextTheme);

    updateThemeUI();
  };

  const bindThemeToggle = () => {
    getThemeButtons().forEach((button) => {
      if (button.dataset.boundThemeHandler) return;

      button.addEventListener('click', toggleTheme);
      button.dataset.boundThemeHandler = 'true';
    });
  };

  const initSpecialModeToggle = () => {
    let clickCount = 0;
    let clickTimer: ReturnType<typeof setTimeout> | null = null;
    
    const triggers = document.querySelectorAll('.sillycat-trigger');
    triggers.forEach(trigger => {
      // Need to handle both a and h1/h2 tags
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        clickCount++;
        
        if (clickTimer) clearTimeout(clickTimer);
        
        clickTimer = setTimeout(() => {
          if (clickCount === 1) {
            const href = trigger.getAttribute('href');
            if (href) {
              window.location.href = href;
            }
          }
          clickCount = 0;
        }, 500);
        
        if (clickCount === 10) {
          if (clickTimer) clearTimeout(clickTimer);
          if (localStorage.getItem('sillycat_special_mode') === 'true') {
            localStorage.removeItem('sillycat_special_mode');
            alert('已退出特别模式');
          } else {
            localStorage.setItem('sillycat_special_mode', 'true');
            alert('特别模式已解锁！');
          }
          clickCount = 0;
          window.location.reload();
        }
      });
    });

    document.addEventListener('click', (e) => {
      if (!e.target || !(e.target as Element).classList.contains('sillycat-trigger')) {
        clickCount = 0;
      }
    });
  };

  const setDrawerState = (open: boolean) => {
    const { drawerRoot, drawerPanel, openButton } = getDrawerElements();
    if (!drawerRoot || !drawerPanel || !openButton) return;

    drawerRoot.classList.toggle('opacity-100', open);
    drawerRoot.classList.toggle('pointer-events-auto', open);
    drawerRoot.classList.toggle('opacity-0', !open);
    drawerRoot.classList.toggle('pointer-events-none', !open);

    drawerPanel.classList.toggle('translate-x-0', open);
    drawerPanel.classList.toggle('translate-x-full', !open);

    drawerRoot.setAttribute('aria-hidden', open ? 'false' : 'true');
    openButton.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  };

  const bindDrawerMenu = () => {
    const { openButton, closeButton, overlayButton } = getDrawerElements();

    if (openButton && !openButton.dataset.boundDrawerHandler) {
      openButton.addEventListener('click', () => setDrawerState(true));
      openButton.dataset.boundDrawerHandler = 'true';
    }

    if (closeButton && !closeButton.dataset.boundDrawerHandler) {
      closeButton.addEventListener('click', () => setDrawerState(false));
      closeButton.dataset.boundDrawerHandler = 'true';
    }

    if (overlayButton && !overlayButton.dataset.boundDrawerHandler) {
      overlayButton.addEventListener('click', () => setDrawerState(false));
      overlayButton.dataset.boundDrawerHandler = 'true';
    }

    document.querySelectorAll<HTMLElement>('[data-mobile-nav-link]').forEach((link) => {
      if (link.dataset.boundDrawerHandler) return;

      link.addEventListener('click', () => setDrawerState(false));
      link.dataset.boundDrawerHandler = 'true';
    });
  };

  const initSidebar = () => {
    bindThemeToggle();
    bindDrawerMenu();
    updateThemeUI();
    initSpecialModeToggle();
    setDrawerState(false);
  };

  if (!document.documentElement.dataset.boundDrawerEscapeHandler) {
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setDrawerState(false);
      }
    });

    document.documentElement.dataset.boundDrawerEscapeHandler = 'true';
  }

  if (!document.documentElement.dataset.boundSidebarPageLoadHandler) {
    document.addEventListener('astro:page-load', initSidebar);
    document.documentElement.dataset.boundSidebarPageLoadHandler = 'true';
  }

  initSidebar();
</script>