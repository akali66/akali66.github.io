---
import Layout from '../layouts/Layout.astro';

const tabs = [
  { id: 'all', name: '全部' },
  { id: 'frontend', name: '前端' },
  { id: 'backend', name: '后端' },
  { id: 'ai', name: 'AI' },
  { id: 'other', name: '其他' },
];

const catColorMap: Record<string, string> = {
  frontend: 'bg-blue-100 text-blue-800 dark:bg-blue-800 dark:text-blue-100',
  backend: 'bg-green-100 text-green-800 dark:bg-green-800 dark:text-green-100',
  ai: 'bg-purple-100 text-purple-800 dark:bg-purple-800 dark:text-purple-100',
  other: 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-100',
};

const tabIds = new Set(tabs.map((tab) => tab.id));
const articleModules = Object.values(import.meta.glob('./articles/**/*.md', { eager: true }));

const articles = articleModules
  .map((entry: any) => {
    const rawCategory = typeof entry.frontmatter.category === 'string'
      ? entry.frontmatter.category.toLowerCase()
      : 'other';
    const category = tabIds.has(rawCategory) ? rawCategory : 'other';
    const rawDate = entry.frontmatter.pubDate ?? entry.frontmatter.date ?? null;
    const date = rawDate ? new Date(rawDate) : null;

    return {
      title: entry.frontmatter.title ?? '未命名文章',
      description: entry.frontmatter.description ?? '',
      url: entry.url ?? '#',
      category,
      date: date && !Number.isNaN(date.getTime()) ? date : null,
    };
  })
  .sort((a, b) => {
    if (a.date && b.date) {
      return b.date.getTime() - a.date.getTime();
    }
    if (a.date) {
      return -1;
    }
    if (b.date) {
      return 1;
    }
    return a.title.localeCompare(b.title, 'zh-CN');
  });

const tabNameMap = Object.fromEntries(tabs.map((tab) => [tab.id, tab.name]));
---

<Layout title="SillyCat的文章">
  <div class="max-w-4xl mx-auto space-y-8" x-data="{ activeTab: 'all' }">
    <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">文章归档</h1>

    <!-- Tabs Navigation -->
    <div class="flex space-x-2 border-b border-gray-200 dark:border-gray-800 overflow-x-auto pb-4">
      {tabs.map((tab) => (
        <button
          class="tab-btn px-4 py-2 font-medium text-sm transition-colors rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100 dark:text-gray-400 dark:hover:text-white dark:hover:bg-gray-800"
          data-tab={tab.id}
        >
          {tab.name}
        </button>
      ))}
    </div>

    <!-- Articles List or Empty State -->
    <div class="mt-8">
      {articles.length === 0 ? (
        <div class="p-12 text-center border-2 border-dashed border-gray-200 dark:border-gray-700 rounded-2xl">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <h3 class="mt-4 text-sm font-medium text-gray-900 dark:text-gray-100">博主正在没日没夜的加班造🚀</h3>
        </div>
      ) : (
        <>
          <ul class="space-y-4" id="article-list">
            {articles.map((article) => (
              <li class="article-item p-6 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900/60 shadow-sm hover:shadow-md transition-shadow" data-category={article.category}>
                <a href={article.url} class="block space-y-3">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <h2 class="min-w-0 flex-1 text-xl font-bold text-gray-900 dark:text-gray-100 line-clamp-2 wrap-break-word" title={article.title}>{article.title}</h2>
                    <span class={`shrink-0 px-2.5 py-1 rounded-full text-xs font-semibold ${catColorMap[article.category] || catColorMap.other}`}>
                      {tabNameMap[article.category] ?? '其他'}
                    </span>
                  </div>
                  {article.description && <p class="text-gray-600 dark:text-gray-300">{article.description}</p>}
                  {article.date && <p class="text-sm text-gray-500 dark:text-gray-400">发布于 {article.date.toLocaleDateString('zh-CN')}</p>}
                </a>
              </li>
            ))}
          </ul>

          <div id="no-results" class="hidden p-12 mt-6 text-center border-2 border-dashed border-gray-200 dark:border-gray-700 rounded-2xl text-sm text-gray-600 dark:text-gray-300">
            当前分类下暂无文章
          </div>
        </>
      )}
    </div>
  </div>

  <script>
    // Tab Logic
    const initTabs = () => {
      const tabBtns = document.querySelectorAll('.tab-btn');
      const articleItems = document.querySelectorAll('.article-item');
      const noResults = document.getElementById('no-results');
      let activeTab = 'all';

      const updateUI = () => {
        tabBtns.forEach(btn => {
          if (btn.getAttribute('data-tab') === activeTab) {
            btn.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-900', 'dark:text-white');
            btn.classList.remove('text-gray-500', 'dark:text-gray-400');
          } else {
            btn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-900', 'dark:text-white');
            btn.classList.add('text-gray-500', 'dark:text-gray-400');
          }
        });
      };

      const updateArticleFilter = () => {
        let visibleCount = 0;

        articleItems.forEach(item => {
          if (!(item instanceof HTMLElement)) {
            return;
          }

          const category = item.getAttribute('data-category');
          const isVisible = activeTab === 'all' || category === activeTab;

          item.style.display = isVisible ? '' : 'none';

          if (isVisible) {
            visibleCount += 1;
          }
        });

        if (noResults) {
          noResults.classList.toggle('hidden', visibleCount !== 0);
        }
      };

      tabBtns.forEach(btn => {
        if (btn instanceof HTMLElement && btn.dataset.bound === 'true') {
          return;
        }

        if (btn instanceof HTMLElement) {
          btn.dataset.bound = 'true';
        }

        btn.addEventListener('click', () => {
          activeTab = btn.getAttribute('data-tab') || 'all';
          updateUI();
          updateArticleFilter();
        });
      });

      updateUI();
      updateArticleFilter();
    };

    // run init inside view transition or normal load
    document.addEventListener('DOMContentLoaded', initTabs);
    // for astro view transitions if used 
    document.addEventListener('astro:page-load', initTabs);
  </script>
</Layout>