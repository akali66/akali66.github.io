---
import Layout from '../layouts/Layout.astro';
---

<Layout title="欢迎来到我的个人小站">
  <div class="max-w-4xl mx-auto space-y-12">
    <!-- Introduction Section -->
    <section class="space-y-6">
      <h2 class="text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">你好，我是 SillyCat</h2>
      <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed max-w-2xl">
        欢迎来到我的个人小站。在这里我会记录我的学习心得、技术见解。以下是我的个人主页，希望你能在这里找到有价值的内容。
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/articles" class="px-6 py-2.5 rounded-full border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition font-medium backdrop-blur-sm">
          阅读文章
        </a>
        <a href="/projects" class="px-6 py-2.5 rounded-full bg-gray-900 text-white hover:bg-gray-800 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-100 transition font-medium">
          浏览项目
        </a>
      </div>
    </section>

    <!-- Featured Works Section -->
    <section class="space-y-6">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div class="space-y-2">
          <p class="text-xs font-semibold tracking-[0.22em] text-gray-500 dark:text-gray-400 uppercase">Some Works</p>
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">一些作品</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300 max-w-xl">
            这里放的是我参与过的一些能展示的作品，记录了从概念到落地的思考与尝试。部分作品存于公司或已经丢失，无法展示，但我会持续更新这个板块，期待未来能展示更多有趣的项目。
          </p>
        </div>

      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <article class="group overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="relative overflow-hidden">
            <button
              type="button"
              class="block w-full cursor-zoom-in text-left"
              data-lightbox-src="/HBB.png"
              data-lightbox-alt="HBB（环保豹）项目设计稿"
              data-lightbox-caption="HBB（环保豹）项目设计稿"
              aria-label="查看 HBB 设计稿大图"
            >
              <img
                src="/HBB.png"
                alt="HBB（环保豹）项目设计稿"
                loading="lazy"
                class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/55 to-transparent px-4 py-3">
                <span class="inline-block rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-gray-900">品牌视觉 · 环保主题</span>
              </div>
            </button>
          </div>
          <div class="space-y-2.5 p-5">
            <h4 class="text-xl font-semibold text-gray-900 dark:text-white">环保豹设计图</h4>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300">
              围绕“环保豹”概念做的项目视觉设计，重点强化识别度和传播感，让画面在环保主题下仍然具备活力与冲击力。
            </p>
          </div>
        </article>

        <article class="group overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="relative overflow-hidden">
            <button
              type="button"
              class="block w-full cursor-zoom-in text-left"
              data-lightbox-src="/SmartPoem.png"
              data-lightbox-alt="SmartPoem（智赋诗韵）项目设计稿"
              data-lightbox-caption="SmartPoem（智赋诗韵）项目设计稿"
              aria-label="查看 SmartPoem 设计稿大图"
            >
              <img
                src="/SmartPoem.png"
                alt="SmartPoem（智赋诗韵）项目设计稿"
                loading="lazy"
                class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/55 to-transparent px-4 py-3">
                <span class="inline-block rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-gray-900">创意产品 · 诗歌交互</span>
              </div>
            </button>
          </div>
          <div class="space-y-2.5 p-5">
            <h4 class="text-xl font-semibold text-gray-900 dark:text-white">智赋诗韵设计图</h4>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300">
              针对“诗词创作体验”设计的视觉方案，通过更柔和的层次和版式节奏，突出灵感生成与内容表达的氛围。
            </p>
          </div>
        </article>
      </div>
    </section>

    <div id="work-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 p-4" aria-hidden="true">
      <button
        type="button"
        id="work-lightbox-close"
        class="absolute right-4 top-4 rounded-full bg-white/20 px-3 py-1 text-2xl leading-none text-white hover:bg-white/35"
        aria-label="关闭大图预览"
      >
        ×
      </button>
      <figure class="w-full max-w-6xl space-y-3">
        <img id="work-lightbox-image" src="" alt="" class="max-h-[82vh] w-full rounded-xl object-contain" />
        <figcaption id="work-lightbox-caption" class="text-center text-sm text-white/90"></figcaption>
      </figure>
    </div>
  </div>
</Layout>

<script is:inline>
  (() => {
    const lightbox = document.getElementById('work-lightbox');
    const previewImage = document.getElementById('work-lightbox-image');
    const caption = document.getElementById('work-lightbox-caption');
    const closeButton = document.getElementById('work-lightbox-close');
    const triggers = document.querySelectorAll('[data-lightbox-src]');

    if (!lightbox || !previewImage || !caption || !closeButton || !triggers.length) return;

    const openLightbox = (src, alt, text) => {
      previewImage.src = src;
      previewImage.alt = alt;
      caption.textContent = text;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const src = trigger.getAttribute('data-lightbox-src');
        const alt = trigger.getAttribute('data-lightbox-alt') || '';
        const text = trigger.getAttribute('data-lightbox-caption') || '';
        if (!src) return;
        openLightbox(src, alt, text);
      });
    });

    closeButton.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox.classList.contains('flex')) {
        closeLightbox();
      }
    });
  })();
</script>
